{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/outstanding-alerts",
      "schedule": "0 2 * * *"
    }
  ]
}
